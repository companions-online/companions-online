{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@shared/*": ["./shared/src/*"],
      "@client-webgl/*": ["./client-webgl/src/*"]
    }
  },
  "include": ["shared/src/**/*", "server/src/**/*", "client-webgl/src/**/*", "cli/**/*", "harness/**/*"],
  "exclude": ["node_modules", "dist"]
}
